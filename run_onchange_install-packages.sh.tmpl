#!/bin/bash
# Brewfile hash: {{ include ".chezmoitemplates/Brewfile" | sha256sum }}
# Re-runs whenever the Brewfile content changes.

set -e

if ! command -v brew &>/dev/null; then
  echo "Homebrew not found — skipping package install."
  exit 0
fi

brew bundle --file=/dev/stdin <<'BREWEOF'
{{ template "Brewfile" . }}
BREWEOF
