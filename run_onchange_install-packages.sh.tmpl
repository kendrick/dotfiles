#!/bin/bash
# Brewfile hash: {{ include ".chezmoitemplates/Brewfile" | sha256sum }}
# Re-runs whenever the Brewfile content changes.

if ! command -v brew &>/dev/null; then
  echo "Homebrew not found — skipping package install."
  exit 0
fi

# Allow failures (MAS apps may need interactive sudo auth)
brew bundle --file=/dev/stdin <<'BREWEOF' || echo "Some Brewfile entries failed (MAS apps may need manual install)."
{{ template "Brewfile" . }}
BREWEOF
